# --- Local MySQL (matches `make db-up` docker-compose container) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=connector
MYSQL_PASSWORD=localtest
MYSQL_DATABASE=app_db

# --- Or, one-line alternative ---
# MYSQL_CONN_STR=mysql://connector:localtest@127.0.0.1:3307/app_db

# --- RapidCanvas deploys (optional, not needed for local) ---
# RAPIDCANVAS_API_KEY=rc-xxxxx
