# DB Explorer — backend env bundled at PROD deploy time
# (see infra/deploy-backend.sh prod)
#
# Copy to app/.env.prod and fill in. Never commit the real file.

APP_ENV=PROD

MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# MYSQL_CONN_STR=mysql://user:pass@host:3306/dbname
